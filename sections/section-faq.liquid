{{ 'section-faq.css' | asset_url | stylesheet_tag }}

{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile

  assign is_slider_autoplay = section.settings.is_slider_autoplay
  assign autoplay_speed = section.settings.autoplay_speed
%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --padding-top: {{ padding_top }}px;
    --padding-bottom: {{ padding_bottom }}px;
    --margin-top: {{ margin_top }}px;
    --margin-bottom: {{ margin_bottom }}px;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      --padding-top: {{ padding_top_mobile }}px;
      --padding-bottom: {{ padding_bottom_mobile }}px;
      --margin-top: {{ margin_top_mobile }}px;
      --margin-bottom: {{ margin_bottom_mobile }}px;
    }
  }
{%- endstyle -%}


<div class="container">
  <div class="faq-wrapper">
    <div class="faq-accordions">
      {% for i in (1..4) %}
        <faq-accordion class="faq-accordion">
          <div class="faq-accordion-head" data-toggle>
            <span class="label">Question</span>
            <span class="icon"></span>
          </div>
  
          <div class="faq-accordion-content" data-content>
            <div class="faq-accordion-content-wrapper">
              Lorem ipsum dolor, sit amet consectetur adipisicing elit. Impedit ipsum quo, earum sed ut culpa quae a ea vero enim. Optio, impedit. Corporis corrupti atque qui eius commodi iusto exercitationem architecto officiis, dignissimos minima quibusdam ullam nulla doloribus culpa pariatur!
            </div>
          </div>
        </faq-accordion>
      {% endfor %}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
    "settings": [
    {
      "type": "header",
      "content": "Spacings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 64
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 120
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Margin Top Mobile",
      "default": 64
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom Mobile",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
